#define __REFLEX_QT_ENABLE_TYPE_REGISTRY  true

#include <reflex/qt/dump.hpp>

@INCLUDES@

using namespace reflex;

int main() {
  static constexpr auto registered = std::define_static_array(qt::detail::object_reg::all());
  template for(constexpr auto t : registered)
  {
    using Type = [:t:];
    qt::dump<Type>();
  }
  return 0;
}

