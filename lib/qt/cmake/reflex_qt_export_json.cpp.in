#define __REFLEX_QT_ENABLE_TYPE_REGISTRY  true

#include <reflex/qt/detail/moc.hpp>

@INCLUDES@

using namespace reflex;

extern "C" int __wrap_main() {
  static constexpr auto types = std::define_static_array(qt::detail::object_reg::all());
  [&]<size_t... I>(std::index_sequence<I...>)
  {
    qt::moc::export_json<typename[:types[I]:]...>("@ARGS_OUTPUT_DIRECTORY@",
                                                  "@ARGS_URI@");
  }(std::make_index_sequence<types.size()>());
  return 0;
}

