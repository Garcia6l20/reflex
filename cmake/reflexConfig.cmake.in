@PACKAGE_INIT@

set(REFLEX_CXX_ABI_VERSION @REFLEX_CXX_ABI_VERSION@)
set(REFLEX_REQUIRED_FLAGS
    -fimplicit-constexpr
    -freflection
    -Wabi=${REFLEX_CXX_ABI_VERSION}
    -fabi-version=${REFLEX_CXX_ABI_VERSION}
)

add_compile_options(${REFLEX_REQUIRED_FLAGS})

set(CMAKE_CXX_STANDARD 26)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_SCAN_FOR_MODULES ON)

set(CMAKE_CXX_MODULE_STD ON)

set(CMAKE_EXPERIMENTAL_CXX_IMPORT_STD "@CMAKE_EXPERIMENTAL_CXX_IMPORT_STD@")

include("${CMAKE_CURRENT_LIST_DIR}/reflex-targets.cmake")
